---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Ngawi Golf Club — a scenic links course on the Wairarapa Coast.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Ngawi Golf Club</title>
  </head>
  <body class="min-h-screen flex flex-col bg-background text-foreground font-sans">
    <!-- Page progress bar -->
    <div id="page-progress" style="position:fixed;top:0;left:0;height:2px;width:0;z-index:9999;background:oklch(0.527 0.136 150);pointer-events:none;transition:opacity 0.3s ease;"></div>
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <footer class="bg-[oklch(0.296_0.083_156)] text-white">
      <div class="max-w-6xl mx-auto px-6 py-12">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
          <div>
            <p class="font-heading text-xl font-semibold mb-1">Ngawi Golf Club</p>
            <p class="text-white/60 text-sm">Ngawi, Wairarapa, New Zealand</p>
          </div>
          <nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-white/60">
            <a href="/course" class="hover:text-white transition-colors">Course</a>
            <a href="/fees" class="hover:text-white transition-colors">Fees</a>
            <a href="/events" class="hover:text-white transition-colors">Events</a>
            <a href="/sponsorship" class="hover:text-white transition-colors">Sponsorship</a>
            <a href="/contact" class="hover:text-white transition-colors">Contact</a>
          </nav>
        </div>
        <div class="mt-8 pt-6 border-t border-white/10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 text-xs text-white/40">
          <p>© {new Date().getFullYear()} Ngawi Golf Club. All rights reserved.</p>
          {import.meta.env.COMING_SOON === 'true' && (
            <button id="coming-soon-toggle" class="text-white/40 hover:text-white/70 underline underline-offset-2 transition-colors cursor-pointer text-left">
              View coming soon page
            </button>
          )}
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  @keyframes progress-run {
    0%   { width: 0% }
    15%  { width: 35% }
    50%  { width: 65% }
    80%  { width: 82% }
    100% { width: 90% }
  }
  #page-progress.loading {
    animation: progress-run 2.5s cubic-bezier(0.1, 0.05, 0.3, 1) forwards;
  }
</style>

<script>
  const bar = document.getElementById('page-progress')!;
  const main = document.querySelector('main')!;

  function closeMobileMenuIfOpen() {
    const menuBtn = document.getElementById('menu-btn');
    if (menuBtn?.getAttribute('aria-expanded') === 'true') {
      menuBtn.click();
    }
  }

  document.getElementById('coming-soon-toggle')?.addEventListener('click', () => {
    document.cookie = 'preview_site=; path=/; max-age=0';
    window.location.href = '/coming-soon';
  });

  document.addEventListener('click', (e) => {
    const link = (e.target as Element).closest('a[href]') as HTMLAnchorElement | null;
    if (!link) return;

    const href = link.getAttribute('href') ?? '';

    if (
      !href ||
      href.startsWith('http') ||
      href.startsWith('//') ||
      href.startsWith('#') ||
      href.startsWith('mailto:') ||
      href.startsWith('tel:')
    ) return;

    closeMobileMenuIfOpen();
    bar.classList.add('loading');
    main.style.transition = 'opacity 0.15s ease';
    main.style.opacity = '0.5';
  });
</script>
