---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Ngawi Golf Club — a scenic links course on the Wairarapa Coast.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Ngawi Golf Club</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-gray-900 font-sans">
    <!-- Page progress bar -->
    <div id="page-progress" style="position:fixed;top:0;left:0;height:3px;width:0;z-index:9999;background:rgb(21 128 61);pointer-events:none;transition:opacity 0.3s ease;"></div>
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <footer class="bg-green-900 text-white py-8">
      <div class="max-w-5xl mx-auto px-4 text-center text-sm">
        <p class="font-semibold text-lg mb-1">Ngawi Golf Club</p>
        <p class="text-green-300">Ngawi, Wairarapa, New Zealand</p>
        <p class="mt-4 text-green-400">© {new Date().getFullYear()} Ngawi Golf Club. All rights reserved.</p>
        {import.meta.env.COMING_SOON === 'true' && (
          <div class="mt-6 pt-6 border-t border-green-700">
            <button id="coming-soon-toggle" class="text-xs text-green-400 hover:text-white underline underline-offset-2 transition-colors cursor-pointer">
              View coming soon page
            </button>
          </div>
        )}
      </div>
    </footer>
  </body>
</html>

<style>
  @keyframes progress-run {
    0%   { width: 0% }
    15%  { width: 35% }
    50%  { width: 65% }
    80%  { width: 82% }
    100% { width: 90% }
  }
  #page-progress.loading {
    animation: progress-run 2.5s cubic-bezier(0.1, 0.05, 0.3, 1) forwards;
  }
</style>

<script>
  const bar = document.getElementById('page-progress')!;
  const main = document.querySelector('main')!;

  // Close mobile menu if open — dispatches a custom event Nav.astro listens for
  function closeMobileMenuIfOpen() {
    const menuBtn = document.getElementById('menu-btn');
    if (menuBtn?.getAttribute('aria-expanded') === 'true') {
      menuBtn.click();
    }
  }

  // Coming soon preview toggle
  document.getElementById('coming-soon-toggle')?.addEventListener('click', () => {
    document.cookie = 'preview_site=; path=/; max-age=0';
    window.location.href = '/coming-soon';
  });

  document.addEventListener('click', (e) => {
    const link = (e.target as Element).closest('a[href]') as HTMLAnchorElement | null;
    if (!link) return;

    const href = link.getAttribute('href') ?? '';

    // Skip: external links, hash anchors, mailto/tel
    if (
      !href ||
      href.startsWith('http') ||
      href.startsWith('//') ||
      href.startsWith('#') ||
      href.startsWith('mailto:') ||
      href.startsWith('tel:')
    ) return;

    // Immediate feedback
    closeMobileMenuIfOpen();
    bar.classList.add('loading');
    main.style.transition = 'opacity 0.15s ease';
    main.style.opacity = '0.5';
  });
</script>
