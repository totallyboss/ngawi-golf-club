---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with Ngawi Golf Club.">
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-bold text-green-900 mb-4">Contact Us</h1>
    <p class="text-gray-600 text-lg mb-10">
      Questions about the course, membership, or upcoming events? Get in touch and we'll get back to you.
    </p>

    <form id="contact-form" class="space-y-4" novalidate>
      <div>
        <label for="c-name" class="block text-sm font-medium text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
        <input id="c-name" name="name" type="text" required
          class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600" />
      </div>

      <div>
        <label for="c-email" class="block text-sm font-medium text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
        <input id="c-email" name="email" type="email" required
          class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600" />
      </div>

      <div>
        <label for="c-message" class="block text-sm font-medium text-gray-700 mb-1">Message <span class="text-red-500">*</span></label>
        <textarea id="c-message" name="message" rows={5} required
          class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600"
          placeholder="How can we help?"></textarea>
      </div>

      <div id="c-error" class="hidden text-sm text-red-600"></div>
      <div id="c-success" class="hidden text-sm text-green-700 font-medium">✓ Message sent! We'll be in touch soon.</div>

      <button type="submit"
        class="bg-green-700 hover:bg-green-800 text-white font-semibold px-6 py-2.5 rounded-md transition-colors text-sm">
        Send Message
      </button>
    </form>
  </div>

  <!-- Visual strip -->
  <img
    src="https://picsum.photos/1000/400"
    alt=""
    aria-hidden="true"
    class="block w-full h-100 object-cover"
  />
</Layout>

<script>
  import { submitForm } from '../lib/formSubmit';
  submitForm('contact-form', 'c-error', 'c-success');
</script>


