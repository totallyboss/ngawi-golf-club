---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with Ngawi Golf Club.">

  <!-- Page header -->
  <section class="border-b border-border">
    <div class="max-w-6xl mx-auto px-6 py-16 md:py-20">
      <h1 class="font-heading text-5xl md:text-6xl font-bold text-[oklch(0.296_0.083_156)] mb-4 leading-tight">Contact Us</h1>
      <p class="text-muted-foreground text-lg max-w-2xl leading-relaxed">
        Questions about the course, membership, or upcoming events? Get in touch and we'll get back to you.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-16">
    <div class="max-w-2xl">
      <form id="contact-form" class="space-y-5" novalidate>
        <div>
          <label for="c-name" class="block text-sm font-medium text-foreground mb-1.5">Name <span class="text-destructive">*</span></label>
          <input id="c-name" name="name" type="text" required
            class="w-full border border-border rounded-xl px-4 py-3 text-sm bg-card focus:outline-none focus:ring-2 focus:ring-[oklch(0.527_0.136_150)] focus:border-transparent transition-all" />
        </div>

        <div>
          <label for="c-email" class="block text-sm font-medium text-foreground mb-1.5">Email <span class="text-destructive">*</span></label>
          <input id="c-email" name="email" type="email" required
            class="w-full border border-border rounded-xl px-4 py-3 text-sm bg-card focus:outline-none focus:ring-2 focus:ring-[oklch(0.527_0.136_150)] focus:border-transparent transition-all" />
        </div>

        <div>
          <label for="c-message" class="block text-sm font-medium text-foreground mb-1.5">Message <span class="text-destructive">*</span></label>
          <textarea id="c-message" name="message" rows={5} required
            class="w-full border border-border rounded-xl px-4 py-3 text-sm bg-card focus:outline-none focus:ring-2 focus:ring-[oklch(0.527_0.136_150)] focus:border-transparent transition-all resize-none"
            placeholder="How can we help?"></textarea>
        </div>

        <div id="c-error" class="hidden text-sm text-destructive"></div>
        <div id="c-success" class="hidden text-sm text-[oklch(0.448_0.119_154)] font-medium">✓ Message sent! We'll be in touch soon.</div>

        <button type="submit"
          class="bg-[oklch(0.296_0.083_156)] hover:bg-[oklch(0.25_0.07_156)] active:scale-95 text-white font-semibold px-7 py-3.5 rounded-xl transition-all text-sm">
          Send Message
        </button>
      </form>
    </div>
  </section>


</Layout>

<script>
  import { submitForm } from '../lib/formSubmit';
  submitForm('contact-form', 'c-error', 'c-success');
</script>
