---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Payment Successful" description="Your payment to Ngawi Golf Club was successful.">
  <div class="max-w-xl mx-auto px-4 py-20 text-center">
    <div class="text-6xl mb-6">✅</div>
    <h1 class="text-3xl font-bold text-green-900 mb-4">Payment Successful</h1>
    <p class="text-gray-600 text-lg mb-6">
      Thank you! Your payment has been received. A receipt has been emailed to you by Stripe.
    </p>
    <p class="text-gray-500 text-sm mb-8">
      If you paid for annual membership, please bring your receipt along to the clubhouse on your first visit.
    </p>
    <a href="/" class="inline-block bg-green-700 hover:bg-green-800 text-white font-semibold px-6 py-3 rounded-md transition-colors">
      Back to Home
    </a>
  </div>
</Layout>
