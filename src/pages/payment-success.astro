---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Payment Successful" description="Your payment to Ngawi Golf Club was successful.">
  <section class="max-w-xl mx-auto px-6 py-28 text-center">
    <div class="w-16 h-16 rounded-full bg-[oklch(0.964_0.015_145)] flex items-center justify-center mx-auto mb-8">
      <svg class="w-8 h-8 text-[oklch(0.448_0.119_154)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 6L9 17l-5-5"/>
      </svg>
    </div>
    <h1 class="font-heading text-4xl md:text-5xl font-bold text-[oklch(0.296_0.083_156)] mb-4">Payment Successful</h1>
    <p class="text-muted-foreground text-lg mb-4 leading-relaxed">
      Thank you! Your payment has been received. A receipt has been emailed to you by Stripe.
    </p>
    <p class="text-muted-foreground/70 text-sm mb-10">
      If you paid for annual membership, please bring your receipt along to the clubhouse on your first visit.
    </p>
    <a href="/"
      class="inline-flex items-center justify-center bg-[oklch(0.296_0.083_156)] hover:bg-[oklch(0.25_0.07_156)] active:scale-95 text-white font-semibold px-7 py-3.5 rounded-xl transition-all text-sm">
      Back to Home
    </a>
  </section>
</Layout>
