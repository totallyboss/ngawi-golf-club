---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero -->
  <section class="relative bg-green-900 text-white py-24 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-5xl md:text-8xl font-bold mb-4 tracking-tight">Ngawi Golf Club</h1>
      <p class="text-lg md:text-xl text-green-200 mb-8 max-w-xl mx-auto">
        Wairarapa's hidden gem - a relaxing and scenic golf course with affordable green fees and NZ Golf accredited memberships for just $120 a year.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/fees" class="inline-block bg-white text-green-900 font-semibold px-6 py-3 rounded-md hover:bg-green-100 transition-colors">
          Pay now and Play
        </a>
        <a href="/course" class="inline-block border border-white text-white font-semibold px-6 py-3 rounded-md hover:bg-green-800 transition-colors">
          About the Course
        </a>
      </div>
    </div>
  </section>

  <!-- Feature cards -->
  <section class="max-w-5xl mx-auto px-4 py-16 grid md:grid-cols-3 gap-8">
    <div class="text-center p-6 rounded-lg border border-gray-200 shadow-sm">
      <div class="text-4xl mb-3">⛳</div>
      <h2 class="text-lg font-semibold mb-2">The Course</h2>
      <p class="text-gray-600 text-sm mb-4">Challenging links golf with stunning views of the Wairarapa coastline.</p>
      <a href="/course" class="text-green-700 font-medium text-sm hover:underline">Learn more →</a>
    </div>
    <div class="text-center p-6 rounded-lg border border-gray-200 shadow-sm">
      <div class="text-4xl mb-3">💳</div>
      <h2 class="text-lg font-semibold mb-2">Fees & Membership</h2>
      <p class="text-gray-600 text-sm mb-4">Green fees from $10 NZD. Join as an annual member for $120 NZD.</p>
      <a href="/fees" class="text-green-700 font-medium text-sm hover:underline">Pay online →</a>
    </div>
    <div class="text-center p-6 rounded-lg border border-gray-200 shadow-sm">
      <div class="text-4xl mb-3">📅</div>
      <h2 class="text-lg font-semibold mb-2">Events</h2>
      <p class="text-gray-600 text-sm mb-4">Club competitions, social rounds, and special events throughout the year.</p>
      <a href="/events" class="text-green-700 font-medium text-sm hover:underline">See events →</a>
    </div>
  </section>

  <section class="relative py-24 px-4 text-center">
    <div class="text-center">
      <h2 class="text-lg font-semibold mb-2">Sponsors</h2>
      <p class="text-gray-600 text-sm mb-4">Thank you to our following sponsors for their support. If you're interested in becoming a sponsor, see our <a href="/sponsorship" class="text-green-700 font-medium text-sm hover:underline">Sponsorship page</a>.</p>

      <div>
        <span>⛳</span>
        <span>⛳</span>
        <span>⛳</span>
        <span>⛳</span>
        <span>⛳</span>
        <span>⛳</span>
        <span>⛳</span>
      </div>
      
    </div>
  </section>
</Layout>
