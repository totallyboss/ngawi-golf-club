---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- =====================================================================
       HERO — VERSION A (two-column, active)
       To switch to centred layout, comment out Version A and uncomment Version B
       ===================================================================== -->
  <section class="bg-green-900 text-white py-16 px-4">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-10 items-center">
      <!-- Left: content -->
      <div>
        <h1 class="font-heading text-5xl md:text-6xl font-bold mb-4 tracking-tight leading-tight">
          Ngawi Golf Club
        </h1>
        <p class="text-lg text-green-200 mb-8 max-w-md">
          Wairarapa's hidden gem — a relaxing and scenic golf course with affordable green fees and NZ Golf accredited memberships for just $120 a year.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/fees" class="inline-block bg-white text-green-900 font-semibold px-6 py-3 rounded-md hover:bg-green-100 transition-colors text-center">
            Pay now and Play
          </a>
          <a href="/course" class="inline-block border border-white text-white font-semibold px-6 py-3 rounded-md hover:bg-green-800 transition-colors text-center">
            About the Course
          </a>
        </div>
      </div>
      <!-- Right: image (visible on all screen sizes, stacks below CTAs on mobile) -->
      <div>
        <img
          src="https://images.unsplash.com/photo-1591491683301-8ef31e8976f2?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
          alt="Golf course with coastal views"
          class="w-full max-h-64 md:max-h-none md:h-72 object-cover rounded-lg shadow-md"
        />
      </div>
    </div>
  </section>

  <!-- =====================================================================
       HERO — VERSION B (centred, fallback — uncomment to use)
       =====================================================================
  <section class="relative bg-green-900 text-white py-24 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-heading text-5xl md:text-8xl font-bold mb-4 tracking-tight">Ngawi Golf Club</h1>
      <p class="text-lg md:text-xl text-green-200 mb-8 max-w-xl mx-auto">
        Wairarapa's hidden gem - a relaxing and scenic golf course with affordable green fees and NZ Golf accredited memberships for just $120 a year.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/fees" class="inline-block bg-white text-green-900 font-semibold px-6 py-3 rounded-md hover:bg-green-100 transition-colors">
          Pay now and Play
        </a>
        <a href="/course" class="inline-block border border-white text-white font-semibold px-6 py-3 rounded-md hover:bg-green-800 transition-colors">
          About the Course
        </a>
      </div>
    </div>
  </section>
  -->

  <!-- Feature cards -->
  <section class="max-w-5xl mx-auto px-4 py-16">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-green-900 text-center mb-10">
      A course unlike any other in New Zealand
    </h2>
    <div class="grid md:grid-cols-3 gap-8">
      <div class="text-center p-6 rounded-lg border border-gray-200 shadow-sm">
        <div class="text-4xl mb-3">⛳</div>
        <h3 class="text-lg font-semibold mb-2">The Course</h3>
        <p class="text-gray-600 text-sm mb-4">Challenging links golf with stunning views of the Wairarapa coastline.</p>
        <a href="/course" class="text-green-700 font-medium text-sm hover:underline">Learn more →</a>
      </div>
      <div class="text-center p-6 rounded-lg border border-gray-200 shadow-sm">
        <div class="text-4xl mb-3">💳</div>
        <h3 class="text-lg font-semibold mb-2">Fees & Membership</h3>
        <p class="text-gray-600 text-sm mb-4">Green fees from $10 NZD. Join as an annual member for $120 NZD.</p>
        <a href="/fees" class="text-green-700 font-medium text-sm hover:underline">Pay online →</a>
      </div>
      <div class="text-center p-6 rounded-lg border border-gray-200 shadow-sm">
        <div class="text-4xl mb-3">📅</div>
        <h3 class="text-lg font-semibold mb-2">Events</h3>
        <p class="text-gray-600 text-sm mb-4">Club competitions, social rounds, and special events throughout the year.</p>
        <a href="/events" class="text-green-700 font-medium text-sm hover:underline">See events →</a>
      </div>
    </div>
  </section>

  <!-- Gallery strip -->
  <div class="py-6">
    <div
      class="flex gap-3 overflow-x-auto scroll-smooth px-4 pb-3"
      style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;"
    >
      <img src="https://picsum.photos/seed/ngawi1/576/384" alt="Golf course" class="h-96 w-[576px] flex-shrink-0 object-cover rounded-lg" style="scroll-snap-align: start;" />
      <img src="https://picsum.photos/seed/ngawi2/576/384" alt="Golf green" class="h-96 w-[576px] flex-shrink-0 object-cover rounded-lg" style="scroll-snap-align: start;" />
      <img src="https://picsum.photos/seed/ngawi3/576/384" alt="Golf at sunset" class="h-96 w-[576px] flex-shrink-0 object-cover rounded-lg" style="scroll-snap-align: start;" />
      <img src="https://picsum.photos/seed/ngawi4/576/384" alt="Coastal golf" class="h-96 w-[576px] flex-shrink-0 object-cover rounded-lg" style="scroll-snap-align: start;" />
      <img src="https://picsum.photos/seed/ngawi5/576/384" alt="Golf course aerial" class="h-96 w-[576px] flex-shrink-0 object-cover rounded-lg" style="scroll-snap-align: start;" />
      <img src="https://picsum.photos/seed/ngawi6/576/384" alt="Morning golf" class="h-96 w-[576px] flex-shrink-0 object-cover rounded-lg" style="scroll-snap-align: start;" />
      <img src="https://picsum.photos/seed/ngawi7/576/384" alt="Golfer playing" class="h-96 w-[576px] flex-shrink-0 object-cover rounded-lg" style="scroll-snap-align: start;" />
      <img src="https://picsum.photos/seed/ngawi8/576/384" alt="Golf clubhouse" class="h-96 w-[576px] flex-shrink-0 object-cover rounded-lg" style="scroll-snap-align: start;" />
      <img src="https://picsum.photos/seed/ngawi9/576/384" alt="Golf flag" class="h-96 w-[576px] flex-shrink-0 object-cover rounded-lg" style="scroll-snap-align: start;" />
      <img src="https://picsum.photos/seed/ngawi10/576/384" alt="Links landscape" class="h-96 w-[576px] flex-shrink-0 object-cover rounded-lg" style="scroll-snap-align: start;" />
    </div>
  </div>

  <!-- Sponsorships -->
  <section class="bg-green-50 py-16 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-green-900 text-center mb-4">
        Proudly Supported By
      </h2>
      <p class="text-gray-600 text-center max-w-xl mx-auto mb-10">
        Our sponsors make the club possible. From local businesses to regional supporters, we're grateful for every partnership.
        Interested in getting your brand in front of golfers and coastal visitors?
        <a href="/sponsorship" class="text-green-700 font-medium hover:underline">Learn about sponsorship →</a>
      </p>
      <!-- Sponsor logo grid: flex-wrap so partial last row centres -->
      <div class="flex flex-wrap justify-center gap-4">
        <div class="bg-gray-100 rounded-lg h-16 w-[calc(50%-0.5rem)] md:w-36 flex items-center justify-center text-gray-400 text-xs">Logo</div>
        <div class="bg-gray-100 rounded-lg h-16 w-[calc(50%-0.5rem)] md:w-36 flex items-center justify-center text-gray-400 text-xs">Logo</div>
        <div class="bg-gray-100 rounded-lg h-16 w-[calc(50%-0.5rem)] md:w-36 flex items-center justify-center text-gray-400 text-xs">Logo</div>
        <div class="bg-gray-100 rounded-lg h-16 w-[calc(50%-0.5rem)] md:w-36 flex items-center justify-center text-gray-400 text-xs">Logo</div>
        <div class="bg-gray-100 rounded-lg h-16 w-[calc(50%-0.5rem)] md:w-36 flex items-center justify-center text-gray-400 text-xs">Logo</div>
        <div class="bg-gray-100 rounded-lg h-16 w-[calc(50%-0.5rem)] md:w-36 flex items-center justify-center text-gray-400 text-xs">Logo</div>
        <div class="bg-gray-100 rounded-lg h-16 w-[calc(50%-0.5rem)] md:w-36 flex items-center justify-center text-gray-400 text-xs">Logo</div>
      </div>
    </div>
  </section>



</Layout>
