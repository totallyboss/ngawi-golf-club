---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">

  <!-- Full-bleed hero -->
  <section class="relative min-h-[88vh] flex items-end">
    <!-- Background image -->
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('https://images.unsplash.com/photo-1591491683301-8ef31e8976f2?q=80&w=2070&auto=format&fit=crop')"
    ></div>
    <!-- Gradient overlay — dark green tint rising from bottom -->
    <div class="absolute inset-0" style="background: linear-gradient(to top, oklch(0.21 0.055 160 / 0.92) 0%, oklch(0.21 0.055 160 / 0.55) 45%, oklch(0.21 0.055 160 / 0.15) 100%)"></div>

    <!-- Content -->
    <div class="relative max-w-6xl mx-auto px-6 pb-20 w-full">
      <p class="text-white/60 text-sm font-medium tracking-widest uppercase mb-4">Wairarapa, New Zealand</p>
      <h1 class="font-heading text-6xl md:text-8xl font-bold text-white mb-6 leading-[1.05] tracking-tight max-w-3xl">
        Ngawi Golf Club
      </h1>
      <p class="text-white/80 text-lg md:text-xl mb-10 max-w-lg leading-relaxed">
        A remote links course on the Palliser Bay coast — unlike any other in New Zealand. Green fees from $10. NZ Accredited Membership for $120/year.
      </p>
      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/fees" class="inline-flex items-center justify-center bg-white text-[oklch(0.296_0.083_156)] font-semibold px-7 py-3.5 rounded-xl hover:bg-white/90 active:scale-95 transition-all text-sm tracking-wide shadow-lg">
          Pay &amp; Play
        </a>
        <a href="/course" class="inline-flex items-center justify-center border border-white/40 bg-white/10 backdrop-blur-sm text-white font-semibold px-7 py-3.5 rounded-xl hover:bg-white/20 active:scale-95 transition-all text-sm tracking-wide">
          About the Course
        </a>
      </div>
    </div>
  </section>

  <!-- Feature cards -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <div class="text-center mb-14">
      <h2 class="font-heading text-4xl md:text-5xl font-bold text-[oklch(0.296_0.083_156)] mb-4 leading-tight">
        A course unlike any other<br class="hidden md:block" /> in New Zealand
      </h2>
      <p class="text-muted-foreground text-lg max-w-2xl mx-auto leading-relaxed">
        Perched at the end of the road on the Palliser Bay coast — raw, windswept, and unforgettable. Affordable for everyone, open to all.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <!-- Card: Course -->
      <a href="/course" class="group relative flex flex-col p-8 rounded-2xl bg-card border border-border hover:border-[oklch(0.527_0.136_150)] hover:shadow-lg transition-all duration-200">
        <div class="mb-5 w-10 h-10 rounded-xl bg-[oklch(0.964_0.015_145)] flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.448 0.119 154)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 17l4-12 4 12"/><path d="M5 13h4"/><path d="M17 3v18"/><path d="M17 3l4 4"/>
          </svg>
        </div>
        <h3 class="font-heading text-xl font-semibold text-foreground mb-2">The Course</h3>
        <p class="text-muted-foreground text-sm leading-relaxed flex-1">Challenging links golf with stunning views of the Wairarapa coastline. 9 holes, par 36.</p>
        <span class="mt-6 text-sm font-medium text-[oklch(0.448_0.119_154)] group-hover:text-[oklch(0.296_0.083_156)] transition-colors">
          Learn more →
        </span>
      </a>

      <!-- Card: Fees -->
      <a href="/fees" class="group relative flex flex-col p-8 rounded-2xl bg-card border border-border hover:border-[oklch(0.527_0.136_150)] hover:shadow-lg transition-all duration-200">
        <div class="mb-5 w-10 h-10 rounded-xl bg-[oklch(0.964_0.015_145)] flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.448 0.119 154)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/>
          </svg>
        </div>
        <h3 class="font-heading text-xl font-semibold text-foreground mb-2">Fees &amp; Membership</h3>
        <p class="text-muted-foreground text-sm leading-relaxed flex-1">Green fees from $10 NZD. Join as an annual member for $120 NZD — NZ Golf accredited.</p>
        <span class="mt-6 text-sm font-medium text-[oklch(0.448_0.119_154)] group-hover:text-[oklch(0.296_0.083_156)] transition-colors">
          Pay online →
        </span>
      </a>

      <!-- Card: Events -->
      <a href="/events" class="group relative flex flex-col p-8 rounded-2xl bg-card border border-border hover:border-[oklch(0.527_0.136_150)] hover:shadow-lg transition-all duration-200">
        <div class="mb-5 w-10 h-10 rounded-xl bg-[oklch(0.964_0.015_145)] flex items-center justify-center">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="oklch(0.448 0.119 154)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
        </div>
        <h3 class="font-heading text-xl font-semibold text-foreground mb-2">Events</h3>
        <p class="text-muted-foreground text-sm leading-relaxed flex-1">Club competitions, social rounds, and Visitors Days throughout the year. All welcome.</p>
        <span class="mt-6 text-sm font-medium text-[oklch(0.448_0.119_154)] group-hover:text-[oklch(0.296_0.083_156)] transition-colors">
          See events →
        </span>
      </a>
    </div>
  </section>

  <!-- Gallery strip -->
  <section class="pb-24">
    <div
      class="flex overflow-x-auto"
      style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none;"
    >
      {[
        { id: 'photo-1591491683301-8ef31e8976f2', alt: 'Golfer on the course' },
        { id: 'photo-1587174486073-ae5e5cff23aa', alt: 'Golf course fairway' },
        { id: 'photo-1553284965-83fd3e82fa5a', alt: 'Links golf landscape' },
        { id: 'photo-1535131749006-b7f58c99034b', alt: 'Golfer teeing off' },
        { id: 'photo-1596727147705-61a532a659bd', alt: 'Coastal golf views' },
      ].map(({ id, alt }) => (
        <img
          src={`https://images.unsplash.com/${id}?q=80&w=700&auto=format&fit=crop`}
          alt={alt}
          class="h-56 md:h-80 w-[75vw] md:w-[520px] flex-shrink-0 object-cover"
          style="scroll-snap-align: start;"
        />
      ))}
    </div>
  </section>

  <!-- Sponsors -->
  <section class="max-w-6xl mx-auto px-6 pb-28">
    <div class="text-center mb-12">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-[oklch(0.296_0.083_156)] mb-3">
        Proudly Supported By
      </h2>
      <p class="text-muted-foreground max-w-lg mx-auto text-sm leading-relaxed">
        Our sponsors make the club possible. Local businesses and regional supporters we're grateful for every partnership.{' '}
        <a href="/sponsorship" class="text-[oklch(0.448_0.119_154)] font-medium hover:text-[oklch(0.296_0.083_156)] transition-colors underline underline-offset-2">
          Become a sponsor →
        </a>
      </p>
    </div>
    <div class="flex flex-wrap justify-center gap-3">
      {Array.from({ length: 9 }).map(() => (
        <div class="bg-muted rounded-xl h-16 w-[calc(50%-0.375rem)] md:w-36 flex items-center justify-center text-muted-foreground/50 text-xs font-medium tracking-wide border border-border">
          Logo
        </div>
      ))}
    </div>
  </section>

</Layout>
