---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sponsorship" description="Sponsorship opportunities at Ngawi Golf Club.">

  <!-- Page header -->
  <section class="border-b border-border">
    <div class="max-w-6xl mx-auto px-6 py-16 md:py-20">
      <h1 class="font-heading text-5xl md:text-6xl font-bold text-[oklch(0.296_0.083_156)] mb-4 leading-tight">Sponsorship</h1>
      <p class="text-muted-foreground text-lg max-w-2xl leading-relaxed">
        Support Ngawi Golf Club and get your brand in front of golfers and visitors on the Wairarapa Coast.
        Three tiers to suit every budget.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-16">

    <!-- Pricing tiers -->
    <div class="grid md:grid-cols-3 gap-6 mb-16">

      <!-- Hole sponsor -->
      <div class="bg-card rounded-2xl border border-border p-8 flex flex-col">
        <h2 class="font-heading text-xl font-semibold text-[oklch(0.296_0.083_156)] mb-2">Hole Sponsor</h2>
        <p class="text-3xl font-bold text-[oklch(0.296_0.083_156)] mb-1">
          $200 <span class="text-sm font-normal text-muted-foreground">/ year</span>
        </p>
        <div class="h-px bg-border my-5"></div>
        <ul class="space-y-3 text-sm flex-1">
          {['Sponsor a named hole', 'Signage at tee', 'Listed on website'].map(item => (
            <li class="flex items-start gap-3 text-foreground">
              <svg class="w-4 h-4 text-[oklch(0.527_0.136_150)] shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none">
                <path d="M3 8l3.5 3.5L13 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Club sponsor (featured) -->
      <div class="bg-card rounded-2xl border-2 border-[oklch(0.448_0.119_154)] p-8 flex flex-col relative">
        <span class="absolute -top-3.5 left-6 bg-[oklch(0.448_0.119_154)] text-white text-xs font-semibold px-3 py-1 rounded-full">Popular</span>
        <h2 class="font-heading text-xl font-semibold text-[oklch(0.296_0.083_156)] mb-2">Club Sponsor</h2>
        <p class="text-3xl font-bold text-[oklch(0.296_0.083_156)] mb-1">
          $500 <span class="text-sm font-normal text-muted-foreground">/ year</span>
        </p>
        <div class="h-px bg-border my-5"></div>
        <ul class="space-y-3 text-sm flex-1">
          {[
            'Logo on clubhouse signage',
            'Featured on website homepage',
            'Named in event communications',
            '4 complimentary green fees',
          ].map(item => (
            <li class="flex items-start gap-3 text-foreground">
              <svg class="w-4 h-4 text-[oklch(0.527_0.136_150)] shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none">
                <path d="M3 8l3.5 3.5L13 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Event sponsor -->
      <div class="bg-card rounded-2xl border border-border p-8 flex flex-col">
        <h2 class="font-heading text-xl font-semibold text-[oklch(0.296_0.083_156)] mb-2">Event Sponsor</h2>
        <p class="text-3xl font-bold text-[oklch(0.296_0.083_156)] mb-1">
          Custom
        </p>
        <div class="h-px bg-border my-5"></div>
        <ul class="space-y-3 text-sm flex-1">
          {[
            'Sponsor a specific event',
            'Branding at event',
            'Prizes / giveaways welcome',
            'Tailored to your budget',
          ].map(item => (
            <li class="flex items-start gap-3 text-foreground">
              <svg class="w-4 h-4 text-[oklch(0.527_0.136_150)] shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none">
                <path d="M3 8l3.5 3.5L13 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Current sponsors -->
    <div class="mb-16">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-[oklch(0.296_0.083_156)] mb-8">Current Sponsors</h2>
      <div class="flex flex-wrap justify-center gap-3">
        {Array.from({ length: 7 }).map(() => (
          <div class="bg-muted rounded-xl h-16 w-[calc(50%-0.375rem)] md:w-36 flex items-center justify-center text-muted-foreground/50 text-xs font-medium tracking-wide border border-border">
            Logo
          </div>
        ))}
      </div>
    </div>

    <!-- Enquiry form -->
    <div class="bg-muted/50 rounded-2xl border border-border p-8 md:p-10">
      <h2 class="font-heading text-2xl font-semibold text-[oklch(0.296_0.083_156)] mb-2">Enquire About Sponsorship</h2>
      <p class="text-muted-foreground text-sm mb-8">Fill in the form below and we'll get back to you promptly.</p>

      <form id="sponsorship-form" class="space-y-5" novalidate>
        <input type="hidden" name="subject" value="Sponsorship Enquiry" />

        <div class="grid md:grid-cols-2 gap-5">
          <div>
            <label for="sp-name" class="block text-sm font-medium text-foreground mb-1.5">Name <span class="text-destructive">*</span></label>
            <input id="sp-name" name="name" type="text" required
              class="w-full border border-border rounded-xl px-4 py-3 text-sm bg-card focus:outline-none focus:ring-2 focus:ring-[oklch(0.527_0.136_150)] focus:border-transparent transition-all" />
          </div>
          <div>
            <label for="sp-email" class="block text-sm font-medium text-foreground mb-1.5">Email <span class="text-destructive">*</span></label>
            <input id="sp-email" name="email" type="email" required
              class="w-full border border-border rounded-xl px-4 py-3 text-sm bg-card focus:outline-none focus:ring-2 focus:ring-[oklch(0.527_0.136_150)] focus:border-transparent transition-all" />
          </div>
        </div>

        <div>
          <label for="sp-business" class="block text-sm font-medium text-foreground mb-1.5">Business / Organisation</label>
          <input id="sp-business" name="business" type="text"
            class="w-full border border-border rounded-xl px-4 py-3 text-sm bg-card focus:outline-none focus:ring-2 focus:ring-[oklch(0.527_0.136_150)] focus:border-transparent transition-all" />
        </div>

        <div>
          <label for="sp-message" class="block text-sm font-medium text-foreground mb-1.5">Message <span class="text-destructive">*</span></label>
          <textarea id="sp-message" name="message" rows={4} required
            class="w-full border border-border rounded-xl px-4 py-3 text-sm bg-card focus:outline-none focus:ring-2 focus:ring-[oklch(0.527_0.136_150)] focus:border-transparent transition-all resize-none"
            placeholder="Which sponsorship package are you interested in? Any questions?"></textarea>
        </div>

        <div id="sp-error" class="hidden text-sm text-destructive"></div>
        <div id="sp-success" class="hidden text-sm text-[oklch(0.448_0.119_154)] font-medium">✓ Thanks! We'll be in touch soon.</div>

        <button type="submit"
          class="bg-[oklch(0.296_0.083_156)] hover:bg-[oklch(0.25_0.07_156)] active:scale-95 text-white font-semibold px-7 py-3.5 rounded-xl transition-all text-sm">
          Send Enquiry
        </button>
      </form>
    </div>
  </section>

  <!-- Visual strip -->
  <div>
    <img
      src="https://images.unsplash.com/photo-1535131749006-b7f58c99034b?q=80&w=2070&auto=format&fit=crop"
      alt=""
      aria-hidden="true"
      class="block w-full h-56 md:h-72 object-cover"
    />
  </div>

</Layout>

<script>
  import { submitForm } from '../lib/formSubmit';
  submitForm('sponsorship-form', 'sp-error', 'sp-success');
</script>
