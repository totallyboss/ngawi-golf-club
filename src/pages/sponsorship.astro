---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sponsorship" description="Sponsorship opportunities at Ngawi Golf Club.">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-bold text-green-900 mb-4">Sponsorship</h1>
    <p class="text-gray-600 text-lg mb-10">
      Ngawi Golf Club welcomes sponsorship from local and national businesses.
      Support the club and get your brand in front of golfers and visitors on the Wairarapa Coast.
    </p>

    <div class="grid md:grid-cols-3 gap-6 mb-12">
      <div class="border border-gray-200 rounded-lg p-5 shadow-sm">
        <h2 class="text-lg font-semibold text-green-900 mb-2">Hole Sponsor</h2>
        <p class="text-2xl font-bold text-green-700 mb-3">$200 <span class="text-sm font-normal text-gray-500">/ year</span></p>
        <ul class="text-sm text-gray-600 space-y-1">
          <li class="flex items-start gap-2"><span class="text-green-600">✓</span> Sponsor a named hole</li>
          <li class="flex items-start gap-2"><span class="text-green-600">✓</span> Signage at tee</li>
          <li class="flex items-start gap-2"><span class="text-green-600">✓</span> Listed on website</li>
        </ul>
      </div>

      <div class="border-2 border-green-700 rounded-lg p-5 shadow-sm relative">
        <span class="absolute -top-3 left-4 bg-green-700 text-white text-xs font-semibold px-2 py-0.5 rounded">Popular</span>
        <h2 class="text-lg font-semibold text-green-900 mb-2">Club Sponsor</h2>
        <p class="text-2xl font-bold text-green-700 mb-3">$500 <span class="text-sm font-normal text-gray-500">/ year</span></p>
        <ul class="text-sm text-gray-600 space-y-1">
          <li class="flex items-start gap-2"><span class="text-green-600">✓</span> Logo on clubhouse signage</li>
          <li class="flex items-start gap-2"><span class="text-green-600">✓</span> Featured on website homepage</li>
          <li class="flex items-start gap-2"><span class="text-green-600">✓</span> Named in event communications</li>
          <li class="flex items-start gap-2"><span class="text-green-600">✓</span> 4 complimentary green fees</li>
        </ul>
      </div>

      <div class="border border-gray-200 rounded-lg p-5 shadow-sm">
        <h2 class="text-lg font-semibold text-green-900 mb-2">Event Sponsor</h2>
        <p class="text-2xl font-bold text-green-700 mb-3">Custom</p>
        <ul class="text-sm text-gray-600 space-y-1">
          <li class="flex items-start gap-2"><span class="text-green-600">✓</span> Sponsor a specific event</li>
          <li class="flex items-start gap-2"><span class="text-green-600">✓</span> Branding at event</li>
          <li class="flex items-start gap-2"><span class="text-green-600">✓</span> Prizes / giveaways welcome</li>
          <li class="flex items-start gap-2"><span class="text-green-600">✓</span> Tailored to your budget</li>
        </ul>
      </div>
    </div>

    <!-- Sponsorship enquiry form -->
    <div class="bg-green-50 rounded-lg p-6">
      <h2 class="text-xl font-semibold text-green-900 mb-4">Enquire About Sponsorship</h2>
      <form id="sponsorship-form" class="space-y-4" novalidate>
        <input type="hidden" name="subject" value="Sponsorship Enquiry" />

        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label for="sp-name" class="block text-sm font-medium text-gray-700 mb-1">Name <span class="text-red-500">*</span></label>
            <input id="sp-name" name="name" type="text" required
              class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600" />
          </div>
          <div>
            <label for="sp-email" class="block text-sm font-medium text-gray-700 mb-1">Email <span class="text-red-500">*</span></label>
            <input id="sp-email" name="email" type="email" required
              class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600" />
          </div>
        </div>

        <div>
          <label for="sp-business" class="block text-sm font-medium text-gray-700 mb-1">Business / Organisation</label>
          <input id="sp-business" name="business" type="text"
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600" />
        </div>

        <div>
          <label for="sp-message" class="block text-sm font-medium text-gray-700 mb-1">Message <span class="text-red-500">*</span></label>
          <textarea id="sp-message" name="message" rows={4} required
            class="w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-600"
            placeholder="Which sponsorship package are you interested in? Any questions?"></textarea>
        </div>

        <div id="sp-error" class="hidden text-sm text-red-600"></div>
        <div id="sp-success" class="hidden text-sm text-green-700 font-medium">✓ Thanks! We'll be in touch soon.</div>

        <button type="submit"
          class="bg-green-700 hover:bg-green-800 text-white font-semibold px-6 py-2.5 rounded-md transition-colors text-sm">
          Send Enquiry
        </button>
      </form>
    </div>
  </div>
</Layout>

<script>
  import { submitForm } from '../lib/formSubmit';
  submitForm('sponsorship-form', 'sp-error', 'sp-success');
</script>
